---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import { SITE_TITLE } from '../consts';
import '../styles/tailwind.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const pathname = Astro.url.pathname;

const canonicalURL = new URL(pathname, Astro.site);

const { title: _title, description } = Astro.props;
const titleWithSite = _title ? `${_title} | ${SITE_TITLE}` : SITE_TITLE;
const title = _title || SITE_TITLE;

const fonts = ['sourcesans3-latin-normal-v15', 'sourcesans3-latin-italic-v15'];
const url = `${Astro.url}`.replace(/\/$/, '');
const imageUrl = new URL('og.webp', `${url}/`);
const metadata = JSON.stringify({
  title: _title || "laymonage's personal website",
  url: `${url}`.replace(/^https?:\/\//, ''),
});
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta content="width=device-width,initial-scale=1" name="viewport" />
<link href="/favicon.svg" rel="icon" type="image/svg+xml" />
<link href="/favicon.ico" rel="icon alternate" type="image/x-icon" />
<meta content={Astro.generator} name="generator" />

<!-- Font preloads -->
{
  fonts.map((font) => (
    <link
      as="font"
      crossorigin="anonymous"
      href={`/fonts/${font}.woff2`}
      rel="preload"
      type="font/woff2"
    />
  ))
}
<link href="https://fonts.googleapis.com" rel="preconnect" />
<link crossorigin href="https://fonts.gstatic.com" rel="preconnect" />

<!-- Canonical URL -->
<link href={canonicalURL} rel="canonical" />

<!-- Primary Meta Tags -->
<title>{titleWithSite}</title>
<meta content={title} name="title" />
<meta content={description} name="description" />
<meta content="light dark" name="color-scheme" />

<!-- Open Graph / Facebook -->
<meta content="website" property="og:type" />
<meta content={Astro.url} property="og:url" />
<meta content={title} property="og:title" />
<meta content={description} property="og:description" />
<meta content={imageUrl} property="og:image" />

<!-- Twitter -->
<meta content="summary_large_image" property="twitter:card" />
<meta content={Astro.url} property="twitter:url" />
<meta content={title} property="twitter:title" />
<meta content={description} property="twitter:description" />
<meta content={imageUrl} property="twitter:image" />

<!-- RSS Feed -->
<link
  href={new URL('rss.xml', Astro.site)}
  rel="alternate"
  title="laymonage's Web Feed"
  type="application/rss+xml"
/>

<!-- Sitemap -->
<link href="/sitemap-index.xml" rel="sitemap" />

<!-- Custom metadata for generating OG images -->
<script data-page-metadata type="application/json" is:inline set:html={metadata}></script>

<!-- Umami -->
{
  !import.meta.env.DEV && (
    <script
      data-website-id="5a052b28-77bf-494e-84cd-7788c0c8cb23"
      defer
      is:inline
      src="/imamu.js"
    />
  )
}
